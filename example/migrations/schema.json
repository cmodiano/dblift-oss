  "views": [
    {
      "name": "v_active_products",
      "schema": "dblift",
      "object_type": "VIEW",
      "dialect": "postgresql",
      "query": "SELECT products.id,\n    products.name,\n    products.description,\n    products.price,\n    products.category,\n    products.stock_quantity\n   FROM products\n  WHERE products.is_active = true\n  ORDER BY products.category, products.name;",
      "columns": [
        "id",
        "name",
        "description",
        "price",
        "category",
        "stock_quantity"
      ],
      "materialized": false,
      "is_updatable": false
    },
    {
      "name": "v_product_sales",
      "schema": "dblift",
      "object_type": "VIEW",
      "dialect": "postgresql",
      "query": "SELECT p.id AS product_id,\n    p.name,\n    p.category,\n    p.price,\n    COALESCE(sum(oi.quantity), 0::bigint) AS total_sold,\n    COALESCE(sum(oi.total_price), 0::numeric) AS total_revenue,\n    count(DISTINCT oi.order_id) AS number_of_orders\n   FROM products p\n     LEFT JOIN order_items oi ON p.id = oi.product_id\n  GROUP BY p.id, p.name, p.category, p.price;",
      "columns": [
        "product_id",
        "name",
        "category",
        "price",
        "total_sold",
        "total_revenue",
        "number_of_orders"
      ],
      "materialized": false,
      "is_updatable": false
    },
    {
      "name": "v_user_order_summary",
      "schema": "dblift",
      "object_type": "VIEW",
      "dialect": "postgresql",
      "query": "SELECT u.id AS user_id,\n    u.username,\n    u.email,\n    count(o.id) AS total_orders,\n    COALESCE(sum(o.total_amount), 0::numeric) AS total_spent,\n    max(o.order_date) AS last_order_date\n   FROM users u\n     LEFT JOIN orders o ON u.id = o.user_id\n  GROUP BY u.id, u.username, u.email;",
      "columns": [
        "user_id",
        "username",
        "email",
        "total_orders",
        "total_spent",
        "last_order_date"
      ],
      "materialized": false,
      "is_updatable": false
    }
  ],
