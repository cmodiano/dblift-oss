[importlinter]
root_packages =
    api
    cli
    config
    core
    db
    integrations
    dblift_pro
    dblift_enterprise

[importlinter:contract:oss-independent-of-higher-tiers]
name = OSS roots must not import PRO/Enterprise
type = forbidden
source_modules =
    api
    cli
    config
    core
    db
    integrations
forbidden_modules =
    dblift_pro
    dblift_enterprise

[importlinter:contract:enterprise-above-pro]
name = pro must not import enterprise
type = forbidden
source_modules =
    dblift_pro
forbidden_modules =
    dblift_enterprise
